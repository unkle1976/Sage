# Database
DATABASE_URL=postgresql+asyncpg://sage:sage_dev@localhost:5432/sage

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# WhatsApp Business API (optional — only needed for WhatsApp channel)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Twilio WhatsApp (optional — alternative to Meta direct integration)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=+14155238886

# WhatsApp provider: "twilio" or "meta"
WHATSAPP_PROVIDER=twilio

# Slack (optional — only needed for Slack channel)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# App settings
APP_NAME=Sage
DEBUG=false
SQL_ECHO=false
